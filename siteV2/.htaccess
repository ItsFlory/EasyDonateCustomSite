RewriteEngine On

# 1. Редирект с сайт.ру/index.html на сайт.ру/
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*)/index\.html [NC]
RewriteRule ^ %1/ [R=301,L]

# 2. Если ты хочешь скрыть слово "index" без расширения (если уже настроил Pretty URLs)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*)/index [NC]
RewriteRule ^ %1/ [R=301,L]

# 1. Исключаем /shop/ из HTML rewrite правил (PHP-файлы)
RewriteRule ^shop/ - [L]

# 2. Убираем расширение .html из видимого адреса (редирект)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# 3. Внутренне подставляем .html, чтобы сервер нашел файл
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*?)/?$ $1.html [L]

# Кеширование статических ресурсов
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(webp|png|jpg|jpeg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "private, must-revalidate, max-age=0"
  </FilesMatch>
</IfModule>